# Copy this file to .env and fill in your values.
# The .env file must NOT be committed to version control.

# Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Forbidden-materials source configuration
# INDEX_PAGE  — full URL of the page that contains the link to the .doc file
# BASE_URL    — scheme + host used to resolve relative href paths
# DOC_LINK_RE — Python regex that captures the relative .doc path from the page HTML
#               (the first capture group must be the path)
INDEX_PAGE=https://sch135.no.net/forbidden/
BASE_URL=https://sch135.no.net
DOC_LINK_RE=href=[\"'](/files/[^\"']+\.doc)[\"']
